# Supabase: クライアント / サーバ両方で参照
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — サーバ専用、絶対クライアントバンドルに混入させない
SUPABASE_SERVICE_ROLE_KEY=

# seed スクリプト用: 初期 admin の Google アカウントメール
ADMIN_EMAIL=

# サイト本番 URL (Origin/CSRF 検証 + OGP 絶対 URL に使う)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Turnstile (匿名コメントのスパム対策、Phase 1 必須)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
