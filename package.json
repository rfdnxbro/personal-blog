    "@testing-library/user-event": "14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "postcss": "8.5.15",
