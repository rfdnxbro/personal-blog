{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", ":semanticCommits"],
  "timezone": "Asia/Tokyo",
  "schedule": ["before 8am on monday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Auto-merge minor and patch updates after CI green",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Major updates need manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["major"]
    },
    {
      "description": "Group devDependencies into a single PR",
      "matchDepTypes": ["devDependencies"],
      "groupName": "devDependencies"
    },
    {
      "description": "Pin Biome exactly and isolate lockfile drift",
      "matchPackageNames": ["@biomejs/biome"],
      "groupName": "biome",
      "rangeStrategy": "pin"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 8am on monday"]
  }
}
